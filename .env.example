# =============================================================================
# MaintainPro — Environment Variables
# Copy this file to .env.local for local development.
# NEVER commit .env.local or any file containing real secrets.
# =============================================================================

# --- Database ---
# Local dev: docker-compose postgres service (see docker-compose.yml)
# Production: set via AWS Secrets Manager and injected by App Runner
DATABASE_URL="postgresql://maintainpro:maintainpro_dev@localhost:5432/maintainpro?schema=public"

# --- NextAuth ---
# NEXTAUTH_URL must match the exact URL your app is served from.
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="REPLACE_ME_openssl_rand_-base64_32"

# --- AWS ---
# For local dev only — in production use an IAM role attached to App Runner
# (no long-lived credentials needed when running on AWS).
# REQUIRED: set these in .env.local for local S3/SES/FCM calls.
AWS_REGION="eu-central-1"
AWS_ACCESS_KEY_ID="AKIAIOSFODNN7EXAMPLE"
AWS_SECRET_ACCESS_KEY="wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY"

# --- S3 ---
# Bucket name should include environment suffix, e.g. maintainpro-uploads-dev
# S3_PUBLIC_URL is the CloudFront distribution URL in front of the bucket.
S3_BUCKET="maintainpro-uploads-dev"
S3_PUBLIC_URL="https://dxxxxxxxxxx.cloudfront.net"

# --- SES ---
# The from-address must be verified in SES (or the whole domain must be verified).
# Request SES production access before go-live — sandbox limits to verified addresses only.
SES_FROM_EMAIL="noreply@example.com"
SES_REPLY_TO="destek@example.com"

# --- FCM ---
# Firebase Cloud Messaging for mobile push notifications.
# FCM_SERVER_KEY is the legacy server key from Firebase project settings → Cloud Messaging.
# REQUIRED: replace with real values before testing push notifications.
FCM_SERVER_KEY="AAAA_EXAMPLE_FCM_SERVER_KEY"
FCM_PROJECT_ID="maintainpro-firebase-project"

# --- App ---
APP_URL="http://localhost:3000"
NODE_ENV="development"
# Log level: error | warn | info | debug
LOG_LEVEL="info"
